Import-Package:\
  jakarta.servlet;jakarta.servlet.http;version="[5,7)",\
  jakarta.servlet.descriptor;version="[5,7)",\
  org.osgi.service.useradmin;resolution:=optional,\
  *

Provide-Capability:\
  osgi.service;objectClass=org.apache.sling.engine.SlingRequestProcessor,\
  osgi.service;objectClass=jakarta.servlet.ServletContext
